PORT=5000
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Admin auth
ADMIN_EMAIL=admin@velvetnights.in
ADMIN_PASSWORD=change-this-admin-password
JWT_SECRET=change-this-long-random-secret
JWT_EXPIRES_IN=2h

# Optional: POST new booking notifications to a webhook URL.
# Example: Slack/Discord/Make/Zapier webhook.
BOOKING_NOTIFICATION_WEBHOOK=

# Firebase Admin SDK
# Use values from Firebase Console > Project settings > Service accounts.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
